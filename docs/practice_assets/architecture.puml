@startuml
title Архитектура разрабатываемой информационно-аналитической системы

top to bottom direction
skinparam componentStyle rectangle
skinparam shadowing true
skinparam packageStyle rectangle
skinparam linetype ortho

actor "Пользователь" as User

rectangle "Пользовательский интерфейс\nReact / TypeScript" as Frontend

package "Серверная часть\nFastAPI" as Backend {
  [Модуль авторизации] as Auth
  [Модуль импорта и предпросмотра] as Import
  [Модуль предобработки] as Prep
  [Модуль сравнительного анализа] as Analysis
  [Модуль проектов и истории] as Storage
  [Модуль отчетности] as Reports
  
}

database "PostgreSQL" as DB
cloud "Объектное хранилище MinIO" as S3

User --> Frontend
Frontend --> Backend : REST API

Auth --> DB
Import --> DB
Import --> S3
Prep --> DB
Analysis --> DB
Storage --> DB
Storage --> S3
Reports --> DB
Reports --> S3

Import --> Prep
Prep --> Analysis
Analysis --> Storage
Analysis --> Reports

@enduml