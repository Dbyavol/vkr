@startuml
title Пользовательский сценарий работы с информационно-аналитической системой

start

:Открытие веб-интерфейса;

if (Требуется авторизация?) then (да)
  :Регистрация или вход в систему;
else (нет)
endif

if (Нужно сохранить работу в проект?) then (да)
  :Выбор или создание проекта;
else (нет)
endif

:Загрузка исходного файла;
:Проверка и предпросмотр данных;

if (Файл корректен?) then (да)
else (нет)
  :Сообщение об ошибке;
  stop
endif

:Настройка предобработки данных;
:Выбор критериев и весов;
:Выбор режима анализа;

if (Выбран поиск аналогов?) then (да)
  :Выбор целевого объекта;
  :Запуск расчета;
  :Расчет близости объектов;
  :Формирование списка аналогов;
  :Отображение аналогов и пояснений;
else (нет)
  :Запуск расчета;
  :Расчет интегральных оценок;
  :Формирование рейтинга объектов;
  :Отображение рейтинга и вкладов критериев;
endif

:Вывод результата сравнения;

if (Нужно сформировать отчет?) then (да)
  :Генерация отчета;
else (нет)
endif

stop
@enduml
